{
	"name": "figma-export-advisor",
	"version": "1.0.0",
	"description": "Figma plugin that analyzes layer content and recommends the optimal export format (SVG, PNG, JPG) based on vector/raster detection, transparency, shadows, blur, and masks.",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "code.js",
	"scripts": {
		"typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome format --write .",
		"build": "rsbuild build",
		"dev": "rsbuild build --watch"
	},
	"pre-commit": [
		"lint",
		"typecheck",
		"build"
	],
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@figma/plugin-typings": "^1.130.0",
		"@rsbuild/core": "^2.1.5",
		"@rspack/cli": "^2.1.3",
		"@rspack/core": "^2.1.3",
		"@types/node": "^24.13.2",
		"figma-plugin-ds": "^1.0.1",
		"pre-commit": "^2.0.0",
		"typescript": "^6.0.3"
	}
}
