{
  "name": "figma-export-advisor",
  "version": "1.0.0",
  "description": "Figma plugin that analyzes layer content and recommends the optimal export format (SVG, PNG, JPG) based on vector/raster detection, transparency, shadows, blur, and masks.",
  "private": true,
  "license": "MIT",
  "author": {
    "email": "dev.divergent044@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Divergent044/figma-export-advisor"
  },
  "type": "module",
  "main": "code.js",
  "scripts": {
    "build": "esbuild src/code.ts --bundle --outfile=code.js --target=es2022 && node scripts/build-ui.mjs",
    "build:code": "esbuild src/code.ts --bundle --outfile=code.js --target=es2022",
    "build:ui": "node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/ui/tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "npm run watch:code & npm run watch:ui",
    "watch:code": "esbuild src/code.ts --bundle --outfile=code.js --target=es2022 --watch=forever",
    "watch:ui": "node scripts/watch-ui.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@figma/plugin-typings": "^1.130.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "figma-plugin-ds": "^1.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
